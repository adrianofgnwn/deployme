# DeployMe — environment variables
# Copy this file to .env and fill in real values. .env is gitignored.
#
# ⚠️  NEVER commit .env to git. NEVER paste real keys into this file.

# ─── API Keys ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-key-here
ADMIN_API_KEY=your-admin-key-here

# ─── Supabase (Backend — both keys, server-side only) ──────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Supabase (Frontend — anon key ONLY, prefixed with VITE_) ──────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# IMPORTANT: NEVER create a VITE_SUPABASE_SERVICE_ROLE_KEY variable.
# The service role key must NEVER be prefixed with VITE_ — Vite exposes all
# VITE_-prefixed vars to the browser bundle. The service role key bypasses
# Row Level Security and would give any visitor full database access.

# ─── ChromaDB ──────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_data

# ─── Models ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LLM_MODEL=claude-sonnet-4-20250514

# ─── Server ────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ─── CORS ──────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173

# ─── Rate Limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
